{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "lockFileMaintenance": {
    "enabled": true
  },
  "argocd": {
    "managerFilePatterns": [
      "/(^|/)application\\..*\\.yaml$/",
      "/^operators\\/.+\\.yaml$/",
      "/^(descheduler|kured)\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)application\\..*\\.yaml$/",
      "/^operators\\/.+\\.yaml$/",
      "/^(descheduler|kured)\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/^(fluentbit|immich|operators|thanos|woodpecker)/.+\\.yaml$/",
      "/^(cloudflared|external-dns|fluentbit-syslog|hyperdx-clickhouse|hyperdx-mongo|jellyfin|kubernetes-event-exporter|mumble|prowlarr|python-envoy-authz|radarr|reloader|sabnzbd|searxng|selfoss|snmp-exporter|sonarr|vpa)\\.yaml$/",
      "/^application\\.hyperdx\\.yaml$/",
      "/^vendored/contour/patch-.+\\.yaml$/"
    ]
  },
  "registryAliases": {
    "registry.apps.nickv.me": "index.docker.io"
  },
  "ignoreDeps": [
    "registry.apps.nickv.me/jellyfin",
    "registry.apps.nickv.me/nijave/cukk",
    "registry.apps.nickv.me/nijave/python-envoy-authz"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s+depName=(?<depName>\\S+)\\s+\\S+?:\\s*\\S+?:(?<currentValue>[^@\\s\"']+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?",
        "# renovate: datasource=(?<datasource>\\S+)(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s+depName=(?<depName>\\S+)\\s*\\n\\s*registry:\\s*\\S+\\s*\\n\\s*tag:\\s*[\"']?(?<currentValue>[^\\s\"'#]+)[\"']?"
      ],
      "datasourceTemplate": "{{#if datasource}}{{datasource}}{{else}}docker{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "CNPG operator — vendored whole-release via vendir (not per-image)",
      "matchManagers": ["vendir"],
      "matchPackageNames": ["cloudnative-pg/cloudnative-pg"],
      "groupName": "cnpg-operator"
    },
    {
      "description": "Barman Cloud Plugin — vendored whole-release via vendir",
      "matchManagers": ["vendir"],
      "matchPackageNames": ["cloudnative-pg/plugin-barman-cloud"],
      "groupName": "barman-cloud-plugin"
    },
    {
      "description": "cert-manager — vendored whole-release via vendir (replaces per-image grouping)",
      "matchManagers": ["vendir"],
      "matchPackageNames": ["cert-manager/cert-manager"],
      "groupName": "cert-manager"
    },
    {
      "description": "external-secrets CRDs — vendored via vendir. NOTE: this git ref must track the Helm chart version in application.external-secrets.yaml; bumps are independent and can drift — review together.",
      "matchManagers": ["vendir"],
      "matchPackageNames": ["external-secrets/external-secrets"],
      "groupName": "external-secrets-crds"
    },
    {
      "description": "Contour — vendored whole-release via vendir; envoy image is tracked separately via kubernetes manager on the overlay patch",
      "matchManagers": ["vendir"],
      "matchPackageNames": ["projectcontour/contour"],
      "groupName": "contour"
    },
    {
      "description": "metrics-server — vendored whole-release via vendir (not per-image)",
      "matchManagers": ["vendir"],
      "matchPackageNames": ["kubernetes-sigs/metrics-server"],
      "groupName": "metrics-server"
    },
    {
      "description": "kubelet-rubber-stamp — group vendir ref and image tag bumps together",
      "matchPackageNames": ["ghcr.io/nijave/kubelet-rubber-stamp", "nijave/kubelet-rubber-stamp"],
      "groupName": "kubelet-rubber-stamp"
    },
    {
      "description": "thanos is handled by the custom regex manager with a registryUrl annotation (registryAliases maps to DockerHub but thanos lives on quay.io)",
      "matchPackageNames": ["**/thanos/thanos"],
      "matchManagers": ["kubernetes"],
      "enabled": false
    },
    {
      "description": "cloudflared is mirrored from cloudflare/cloudflared on DockerHub",
      "matchPackageNames": ["cloudflare/cloudflared"]
    },
    {
      "description": "Bump altinity-clickhouse-operator chart and CRD git ref together",
      "matchPackageNames": [
        "altinity-clickhouse-operator",
        "Altinity/clickhouse-operator"
      ],
      "groupName": "altinity-clickhouse-operator"
    },
    {
      "description": "Group ClickHouse server and keeper images together",
      "matchPackageNames": [
        "clickhouse/clickhouse-server",
        "clickhouse/clickhouse-keeper"
      ],
      "groupName": "clickhouse"
    },
    {
      "description": "Group exportarr sidecars into a single PR",
      "matchPackageNames": ["ghcr.io/onedr0p/exportarr"],
      "groupName": "exportarr"
    },
    {
      "description": "Group VPA components into a single PR",
      "matchPackageNames": [
        "registry.k8s.io/autoscaling/vpa-recommender",
        "registry.k8s.io/autoscaling/vpa-updater",
        "registry.k8s.io/autoscaling/vpa-admission-controller"
      ],
      "groupName": "vpa"
    },
    {
      "description": "Only update kube-prometheus-stack on Fridays",
      "matchPackageNames": ["kube-prometheus-stack"],
      "schedule": ["on friday"]
    },
    {
      "description": "Only update Sonarr on Fridays",
      "matchPackageNames": ["lscr.io/linuxserver/sonarr"],
      "schedule": ["on friday"]
    },
    {
      "description": "Only update SABnzbd on Fridays",
      "matchPackageNames": ["lscr.io/linuxserver/sabnzbd"],
      "schedule": ["on friday"]
    },
    {
      "description": "Only update Radarr on Fridays",
      "matchPackageNames": ["lscr.io/linuxserver/radarr"],
      "schedule": ["on friday"]
    },
    {
      "description": "Only update Prowlarr on Fridays",
      "matchPackageNames": ["lscr.io/linuxserver/prowlarr"],
      "schedule": ["on friday"]
    },
    {
      "description": "thanos-receive-controller uses date-based tags (main-YYYY-MM-DD-hash)",
      "matchPackageNames": ["quay.io/observatorium/thanos-receive-controller"],
      "versioning": "regex:^main-(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2})-[a-f0-9]+$"
    }
  ]
}
